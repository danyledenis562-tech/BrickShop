APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Повний базовий URL сайту (обов’язково з підпапкою, якщо XAMPP: /lego-shop3/public)
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Локально: mysql. На Render: pgsql + DATABASE_URL з панелі (або render.yaml fromDatabase).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Render PostgreSQL (один рядок замість DB_*), Laravel підхопить автоматично для pgsql:
# DB_CONNECTION=pgsql
# DATABASE_URL=postgres://user:pass@host:5432/lego_shop

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local XAMPP/Windows: use "log" (letters in storage/logs) or 127.0.0.1 if Mailpit runs on the host.
# Docker/Sail: smtp + host mailpit, port 1025
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Ключ з кабінету Nova Poshta → Налаштування → Безпека → API-ключ (v2 JSON)
NOVA_POSHTA_API_KEY=
# Якщо змінна названа інакше в хостингу:
# NOVAPOSHTA_API_KEY=
# За потреби інший endpoint (рідко):
# NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/

# Test payment webhook: POST /payments/test-webhook with JSON {"order_id":1} and header X-Test-Payment-Secret
SHOP_TEST_PAYMENT_WEBHOOK_SECRET=

# Low stock warning threshold (1–N units)
SHOP_LOW_STOCK_THRESHOLD=5

# Логотип: за замовчуванням public/images/brickshop-logo.svg у репо; свій файл або URL:
# SHOP_LOGO_PATH=images/my-logo.png
# SHOP_LOGO_URL=https://example.com/logo.png
# SHOP_LOGO_TEXT=Brick Shop
# Якщо логотип уже містить текст (PNG): SHOP_LOGO_HIDE_WORDMARK=true

# LiqPay (https://www.liqpay.ua) — leave empty to hide online payment at checkout
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SANDBOX=true

# Cloudinary (optional, for hosting product images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=brickshop/products
